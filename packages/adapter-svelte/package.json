{
  "name": "figma-code-link-svelte",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "svelte": "dist/index.js",
  "bin": {
    "figma-link-server": "dist/bin/figma-link-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "svelte": "./dist/index.js"
    },
    "./preprocess": {
      "types": "./dist/preprocess/cidPreprocessor.d.ts",
      "default": "./dist/preprocess/cidPreprocessor.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs"
  },
  "dependencies": {
    "figma-code-link-core": "0.0.1",
    "html2canvas": "^1.4.1"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "vite": ">=6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "svelte": "5.46.0",
    "vite": "^7.0.4",
    "typescript": "^5.0.0"
  }
}
