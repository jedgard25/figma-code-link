{
  "name": "figma-code-link-nextjs",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "figma-link-server": "dist/bin/figma-link-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./babel/cid-preprocessor": {
      "types": "./dist/babel/cid-preprocessor.d.ts",
      "default": "./dist/babel/cid-preprocessor.js"
    },
    "./dist/babel/cid-preprocessor": {
      "types": "./dist/babel/cid-preprocessor.d.ts",
      "default": "./dist/babel/cid-preprocessor.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "yalc:publish": "npm run build && npx yalc publish",
    "yalc:push": "npm run build && npx yalc push"
  },
  "dependencies": {
    "figma-code-link-core": "0.0.1",
    "html2canvas": "^1.4.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "@types/react": "^19.2.3",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@babel/core": ">=7.0.0",
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  }
}
